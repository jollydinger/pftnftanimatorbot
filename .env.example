# Bot wallet seed (from create_wallet or your existing wallet)
BOT_SEED=sEdYourBotSeedHere

# fal.ai API key — https://fal.ai/dashboard/keys
FAL_KEY=your_fal_ai_key_here

# OpenRouter API key — https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here

# How often to poll for new messages (milliseconds)
POLL_INTERVAL_MS=10000

# Set to "true" to re-register the bot on every startup (normally only needed once)
FORCE_REGISTER=false
